---
import Layout from '../../layouts/Layout.astro';
import NavProject from '../../components/NavProject.astro';
import InfoOverlay from '../../components/InfoOverlay.tsx';
import ProjectDetails_Unboxed from '../../components/ProjectDetails_Unboxed.tsx';
import ProjectDetails_Unboxed_Mobile from '../../components/ProjectDetails_Unboxed_Mobile.tsx';
import ScrollGallery_Unboxed from '../../components/ScrollGallery_Unboxed.tsx';
import ScrollTop_Unboxed from '../../components/ScrollTop_Unboxed.tsx';
import ProjectLabels_Unboxed from '../../components/ProjectLabels_Unboxed.tsx';
import ProjectLabels_Unboxed_Mobile from '../../components/ProjectLabels_Unboxed_Mobile.tsx';
---

<Layout title="Unboxed Magazine — Bao Ngoc">
    <style>
        html, body { overflow: hidden; }
        .prev-project {
            position: fixed;
            bottom: 10px;
            left: 10px;
            font-family: 'Coordinates Variable', sans-serif;
            font-size: 10px;
            font-weight: 300;
            letter-spacing: 0em;
            line-height: 12px;
            color: rgb(116, 116, 116);
            text-decoration: none;
            z-index: 100;
        }
        .next-project {
            position: fixed;
            bottom: 10px;
            right: 10px;
            font-family: 'Coordinates Variable', sans-serif;
            font-size: 10px;
            font-weight: 300;
            letter-spacing: 0em;
            line-height: 12px;
            color: rgb(116, 116, 116);
            text-decoration: none;
            z-index: 100;
        }
        .back-to-top-wrapper {
            position: fixed;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 100;
        }
    </style>

    <NavProject projectDetails="Project Details" />
    <InfoOverlay client:load />
    <ScrollGallery_Unboxed client:load />
    <ProjectDetails_Unboxed client:load />
    <ProjectDetails_Unboxed_Mobile client:load />
    <ProjectLabels_Unboxed client:load />
    <ProjectLabels_Unboxed_Mobile client:load />

    <div class="back-to-top-wrapper">
        <ScrollTop_Unboxed client:load />
    </div>
    <a href="/projects/riel-studio" class="prev-project">Previous Project</a>
    <a href="/projects/dressing-the-screen" class="next-project">Next Project</a>
</Layout>