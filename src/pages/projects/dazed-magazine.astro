---
import NavProject from '../../components/NavProject.astro';
import InfoOverlay from '../../components/InfoOverlay.tsx';
import ProjectDetails_Dazed from '../../components/ProjectDetails_Dazed.tsx';
import ProjectDetails_Dazed_Mobile from '../../components/ProjectDetails_Dazed_Mobile.tsx';
import ScrollGallery_Dazed from '../../components/ScrollGallery_Dazed.tsx';
import ScrollTop_DAZED from '../../components/ScrollTop_DAZED.tsx';
import ProjectLabels_Dazed from '../../components/ProjectLabels_Dazed.tsx';
import ProjectLabels_Dazed_Mobile from '../../components/ProjectLabels_Dazed_Mobile.tsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dazed Magazine — Bao Ngoc</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      html, body {
        background: #fff;
        overflow: hidden;
        width: 100%;
        height: 100%;
      }

      @font-face {
        font-family: 'Romie';
        src: url('/fonts/Romie-Regular.woff2') format('woff2'),
             url('/fonts/Romie-Regular.woff') format('woff');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Coordinates Variable';
        src: url('/fonts/Coordinates Variables .otf') format('opentype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      .prev-project {
        position: fixed;
        bottom: 10px;
        left: 10px;
        font-family: 'Coordinates Variable', sans-serif;
        font-size: 10px;
        font-weight: 300;
        letter-spacing: 0em;
        line-height: 12px;
        color: rgb(116, 116, 116);
        text-decoration: none;
        z-index: 100;
      }

      .back-to-top-wrapper {
        position: fixed;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
      }
    </style>
  </head>
  <body>
    <NavProject projectDetails="Project Details" />
    <InfoOverlay client:load />
    <ScrollGallery_Dazed client:load />
    <ProjectDetails_Dazed client:load />
    <ProjectDetails_Dazed_Mobile client:load />
    <ProjectLabels_Dazed client:load />
    <ProjectLabels_Dazed_Mobile client:load />
    <div class="back-to-top-wrapper">
      <ScrollTop_DAZED client:load />
    </div>
    <a href="/projects/dressing-the-screen" class="prev-project">Previous Project</a>
  </body>
</html>