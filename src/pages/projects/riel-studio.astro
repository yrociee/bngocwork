---
import NavProject from '../../components/NavProject.astro';
import InfoOverlay from '../../components/InfoOverlay.tsx';
import ProjectDetails_Riel from '../../components/ProjectDetails_Riel.tsx';
import ProjectDetails_Riel_Mobile from '../../components/ProjectDetails_Riel_Mobile.tsx';
import ScrollGallery_Riel from '../../components/ScrollGallery_Riel.tsx';
import ScrollTop_Riel from '../../components/ScrollTop_Riel.tsx';
import ProjectLabels_Riel from '../../components/ProjectLabels_Riel.tsx';
import ProjectLabels_Riel_Mobile from '../../components/ProjectLabels_Riel_Mobile.tsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Riel Studio — Bao Ngoc</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      html, body {
        background: #fff;
        overflow: hidden;
        width: 100%;
        height: 100%;
      }

      @font-face {
        font-family: 'Romie';
        src: url('/fonts/Romie-Regular.woff2') format('woff2'),
             url('/fonts/Romie-Regular.woff') format('woff');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Coordinates Variable';
        src: url('/fonts/Coordinates Variables .otf') format('opentype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      .next-project {
        position: fixed;
        bottom: 10px;
        right: 10px;
        font-family: 'Coordinates Variable', sans-serif;
        font-size: 10px;
        font-weight: 300;
        letter-spacing: 0em;
        line-height: 12px;
        color: rgb(116, 116, 116);
        text-decoration: none;
        z-index: 100;
      }

      .back-to-top-wrapper {
        position: fixed;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
      }

      .desktop { display: block; }
      .mobile  { display: none;  }

      @media (max-width: 808px) {
        .desktop { display: none;  }
        .mobile  { display: block; }
      }
    </style>
  </head>
  <body>
    <NavProject projectDetails="Project Details" />
    <InfoOverlay client:load />
    <ScrollGallery_Riel client:load />

    <!-- Desktop only -->
    <div class="desktop">
      <ProjectDetails_Riel client:load />
      <ProjectLabels_Riel client:load />
    </div>

    <!-- Mobile only -->
    <div class="mobile">
      <ProjectDetails_Riel_Mobile client:load />
      <ProjectLabels_Riel_Mobile client:load />
    </div>

    <!-- Shared -->
    <div class="back-to-top-wrapper">
      <ScrollTop_Riel client:load />
    </div>
    <a href="/projects/unboxed-magazine" class="next-project">Next Project</a>
  </body>
</html>